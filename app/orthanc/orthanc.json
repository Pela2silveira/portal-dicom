{
  "Name": "RedImagenesNQN-orthanc",
  "StorageDirectory": "/var/lib/orthanc/storage",
  "IndexDirectory": "/var/lib/orthanc/db",
  "HttpPort": 8042,
  "DicomPort": 4242,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,
  "RegisteredUsers": {},
  "DicomAet": "ORTHANC",
  "DicomCheckCalledAet": false,
  "DicomAlwaysAllowEcho": true,
  "Plugins": [
    "/usr/local/share/orthanc/plugins"
  ],
  "OrthancExplorerEnabled": true,
  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/"
  },
  "StoneWebViewer": {
    "ShowNotForDiagnosticUsageDisclaimer": false
  },
  "Authorization": {
    "WebServiceTokenCreationBaseUrl": "http://backend:8081/api/orthanc-auth/tokens/",
    "WebServiceTokenDecoderUrl": "http://backend:8081/api/orthanc-auth/tokens/decode",
    "WebServiceTokenValidationUrl": "http://backend:8081/api/orthanc-auth/tokens/validate",
    "WebServiceUserProfileUrl": "http://backend:8081/api/orthanc-auth/user/get-profile",
    "TokenHttpHeaders": [
      "cookie",
      "x-orthanc-internal-token"
    ],
    "TokenGetArguments": [
      "token"
    ],
    "CheckedLevel": "studies",
    "Permissions": [
      ["post", "^/tools/find$", "all|viewer-tools-find"],
      ["get", "^/studies/([A-Za-z0-9-]+)/archive$", "all"],
      ["get", "^/jobs/([A-Za-z0-9-]+)$", "all"],
      ["put", "^/modalities/([^/]+)$", "all"],
      ["post", "^/modalities/([^/]+)/(echo|get)$", "all"]
    ],
    "StandardConfigurations": [
      "stone-webviewer"
    ]
  }
}
